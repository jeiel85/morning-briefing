# ── Database (required) ───────────────────────────────────────────
# Prisma reads POSTGRES_PRISMA_URL (see prisma/schema.prisma).
# On Vercel, the Vercel Postgres / Neon integration injects this automatically.
# For local dev, point it at your Postgres instance.
POSTGRES_PRISMA_URL=postgresql://user:password@localhost:5432/dawnbrief

# ── Internal job auth (required) ──────────────────────────────────
# Shared secret for internal job routes: /api/ingestion/fetch,
# /api/briefing/generate, /api/push/send, /api/maintenance/cleanup.
# Also set as a GitHub Actions secret for the ingestion workflow.
INTERNAL_JOB_TOKEN=replace_me

# ── Cron auth (required in production) ─────────────────────────────
# Vercel Cron sends "Authorization: Bearer $CRON_SECRET" to /api/cron/briefing.
# If unset, the cron endpoint rejects every request (fail closed).
CRON_SECRET=replace_me

# ── App URL (recommended in production) ───────────────────────────
# Used for cron self-calls and the web-push mailto subject.
# Falls back to https://zam-dun.vercel.app when unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Web Push / VAPID (required for push notifications) ────────────
# Generate a keypair with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=replace_me
VAPID_PRIVATE_KEY=replace_me
# Optional: expose the public key to the client. Must equal VAPID_PUBLIC_KEY.
# If unset, the client uses a built-in fallback key.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace_me

# ── LLM summarization (optional) ──────────────────────────────────
# Without a key, briefings fall back to snippet extraction + Google Translate.
OPENAI_API_KEY=replace_me

# ── Admin (optional) ──────────────────────────────────────────────
# Comma-separated visitor IDs (the db_visitor cookie value) allowed to toggle
# global sources. Unset → source management is read-only for everyone.
ADMIN_VISITOR_IDS=

# ── Misc (optional) ───────────────────────────────────────────────
# "production" switches the logger to structured JSON output.
APP_ENV=development
