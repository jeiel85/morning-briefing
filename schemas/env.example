# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
INTERNAL_JOB_TOKEN=replace_me

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dawnbrief

# Auth
AUTH_SECRET=replace_me
